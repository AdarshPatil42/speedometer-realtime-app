generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SpeedData {
  id        Int      @id @default(autoincrement())
  speed     Float
  createdAt DateTime @default(now())
}